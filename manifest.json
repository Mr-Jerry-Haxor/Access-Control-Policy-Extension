{
  "manifest_version": 3,
  "name": "ACP Validator",
  "description": "AI-powered Access Control Policy validation extension for CAIRO assessments.",
  "version": "1.0.0",


  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab"
  ],

  "host_permissions": [
    "*://cairois.web.boeing.com/*",
    "*://boeingai.web.boeing.com/*"
  ],

  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ACP Validator"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}